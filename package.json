{
  "name": "hallmark-identity",
  "version": "0.0.0",
  "description": "Open, IDP-agnostic agent-identity toolkit: agent + on-behalf-of tokens via RFC 8693.",
  "type": "module",
  "license": "MIT",
  "author": "smithingdev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smithingdev/hallmark-identity.git"
  },
  "homepage": "https://github.com/smithingdev/hallmark-identity",
  "bugs": {
    "url": "https://github.com/smithingdev/hallmark-identity/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
